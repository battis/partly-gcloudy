{
  "name": "@battis/partly-gcloudy",
  "version": "2.0.0",
  "description": "Idiosyncratic collection of interactions with `gcloud` CLI tool",
  "license": "GPL-3.0",
  "author": {
    "name": "Seth Battis",
    "url": "https://github.com/battis"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "clean": "del ./dist ./tmp",
    "build": "run-s build:*",
    "build:clean": "run-s clean",
    "build:scripts": "tsc -p ./tsconfig.scripts.json",
    "build:google-services": "source .env; ./scripts/services -v --serviceAccountToken \"$(op item get --account $OP_ACCOUNT --reveal --fields credential $OP_TOKEN)\"",
    "build:compile": "tsc",
    "release": "run-s release:*",
    "release:build": "run-s build",
    "release:commit-and-tag-version": "commit-and-tag-version",
    "release:main": "git push --follow-tags; git checkout main; git merge dev; git push",
    "release:publish": "pnpm publish --access=public",
    "release:dev": "git checkout dev"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.10.1",
    "change-case-all": "^2.1.0",
    "lodash": "^4.17.21",
    "ora": "^8.2.0",
    "rword": "^4.0.0",
    "rword-english-extended": "^1.0.0"
  },
  "devDependencies": {
    "@battis/descriptive-types": "^0.2.6",
    "@battis/eslint-config": "^2.0.7",
    "@battis/prettier-config": "^1.7.1",
    "@battis/typescript-tricks": "^0.7.5",
    "@qui-cli/colors": "^3.1.0",
    "@qui-cli/core": "^5.0.0",
    "@qui-cli/env-1password": "^1.0.5",
    "@qui-cli/log": "^4.0.1",
    "@qui-cli/plugin": "^4.0.0",
    "@qui-cli/root": "^3.0.4",
    "@qui-cli/shell": "^3.0.3",
    "@qui-cli/validators": "^3.0.2",
    "@tsconfig/node22": "^22.0.5",
    "@types/lodash": "^4.17.21",
    "@types/node": "^24.10.1",
    "commit-and-tag-version": "^12.6.1",
    "del-cli": "^6.0.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@qui-cli/colors": "3.x",
    "@qui-cli/core": "5.x",
    "@qui-cli/env-1password": "1.x",
    "@qui-cli/log": "4.x",
    "@qui-cli/plugin": "4.x",
    "@qui-cli/root": "3.x",
    "@qui-cli/shell": "3.x",
    "@qui-cli/validators": "3.x"
  },
  "packageManager": "pnpm@10.12.4",
  "engines": {
    "node": ">=12.17"
  },
  "target": "node"
}
