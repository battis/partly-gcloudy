{
  "name": "@battis/partly-gcloudy",
  "version": "3.2.0",
  "description": "Idiosyncratic collection of interactions with `gcloud` CLI tool",
  "license": "GPL-3.0",
  "author": {
    "name": "Seth Battis",
    "url": "https://github.com/battis"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "clean": "del ./dist ./tmp",
    "build": "run-s build:*",
    "build:clean": "run-s clean",
    "build:scripts": "tsc -p ./tsconfig.scripts.json",
    "build:google-services": "./scripts/services -v",
    "build:compile": "tsc",
    "release": "run-s release:*",
    "release:build": "run-s build",
    "release:commit-and-tag-version": "commit-and-tag-version",
    "release:main": "git push --follow-tags",
    "release:npm":"pnpm login",
    "release:publish": "pnpm publish --access=public"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.10.1",
    "change-case-all": "^2.1.0",
    "lodash": "^4.17.21",
    "ora": "^8.2.0",
    "rword": "^4.0.0",
    "rword-english-extended": "^1.0.0"
  },
  "devDependencies": {
    "@battis/descriptive-types": "^0.2.6",
    "@battis/eslint-config": "^2.0.9",
    "@battis/prettier-config": "^1.7.3",
    "@battis/typescript-tricks": "^0.7.6",
    "@qui-cli/colors": "^3.2.1",
    "@qui-cli/core": "^5.0.2",
    "@qui-cli/env-1password": "^1.2.5",
    "@qui-cli/log": "^4.0.2",
    "@qui-cli/plugin": "^4.0.0",
    "@qui-cli/root": "^3.0.6",
    "@qui-cli/shell": "^3.1.1",
    "@qui-cli/validators": "^3.0.3",
    "@tsconfig/node24": "^24.0.3",
    "@types/lodash": "^4.17.21",
    "@types/node": "^24.10.4",
    "commit-and-tag-version": "^12.6.1",
    "del-cli": "^6.0.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@qui-cli/colors": ">=3",
    "@qui-cli/core": ">=4",
    "@qui-cli/env-1password": ">=1",
    "@qui-cli/log": ">=3",
    "@qui-cli/plugin": ">=3",
    "@qui-cli/root": ">=3",
    "@qui-cli/shell": ">=3",
    "@qui-cli/validators": ">=3"
  },
  "packageManager": "pnpm@10.12.4",
  "engines": {
    "node": ">=12.17"
  },
  "target": "node"
}
