{
  "name": "@battis/partly-gcloudy",
  "version": "3.4.5",
  "description": "Idiosyncratic collection of interactions with `gcloud` CLI tool",
  "license": "GPL-3.0",
  "author": {
    "name": "Seth Battis",
    "url": "https://github.com/battis"
  },
  "type": "module",
  "imports": {
    "#app": "./dist/app/index.js",
    "#batch": "./dist/batch/index.js",
    "#billing": "./dist/billing/index.js",
    "#core": "./dist/core.js",
    "#iam": "./dist/iam/index.js",
    "#iap": "./dist/iap/index.js",
    "#lib": "./dist/lib/index.js",
    "#projects": "./dist/projects/index.js",
    "#run": "./dist/run/index.js",
    "#secrets": "./dist/secrets/index.js",
    "#services": "./dist/services/index.js",
    "#shell": "./dist/shell/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "clean": "del ./dist ./tmp",
    "build": "run-s build:*",
    "build:clean": "run-s clean",
    "build:setup": "run-s setup",
    "build:scripts": "tsc -p ./tsconfig.scripts.json",
    "build:google-services": "./scripts/services -v",
    "build:compile": "tsc",
    "prepack": "run-s build",
    "release": "run-s release:*",
    "release:commit-and-tag-version": "commit-and-tag-version",
    "release:main": "git push --follow-tags",
    "release:npm": "pnpm login",
    "release:publish": "pnpm publish --access=public",
    "postinstall": "run-s setup",
    "setup": "run-s setup:*",
    "setup:prettier": "setup-prettier -f",
    "setup:eslint": "setup-eslint -f",
    "setup:commit": "setup-commit -f"
  },
  "dependencies": {
    "change-case-all": "^2.1.0",
    "lodash": "^4.18.1",
    "ora": "^8.2.0",
    "rword": "^4.0.0",
    "rword-english-extended": "^1.0.0"
  },
  "devDependencies": {
    "@1password/sdk": "^0.4.0",
    "@battis/commit": "^0.0.4",
    "@battis/descriptive-types": "^0.2.6",
    "@battis/eslint": "^3.0.2",
    "@battis/monorepo": "^0.0.3",
    "@battis/prettier": "^2.0.4",
    "@battis/typescript-tricks": "^0.8.4",
    "@tsconfig/node-lts": "^24.0.0",
    "@types/lodash": "^4.17.24",
    "@types/node": "^24.13.2",
    "del-cli": "^6.0.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.9.4",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@inquirer/prompts": ">=6",
    "@qui-cli/colors": ">=3.2",
    "@qui-cli/core": ">=4",
    "@qui-cli/env": ">=5",
    "@qui-cli/log": ">=3",
    "@qui-cli/plugin": ">=3",
    "@qui-cli/root": ">=3",
    "@qui-cli/shell": ">=3",
    "@qui-cli/validators": ">=3"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
  "target": "node"
}
